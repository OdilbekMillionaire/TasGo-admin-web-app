# Store Config
STORE_NAME=TasGo
STORE_OPERATING_HOURS=24/7
MIN_ORDER_FREE_DELIVERY_UZS=30000
DELIVERY_FEE_UZS=5000

# Next.js public env (prefix with NEXT_PUBLIC_ for client-side access)
NEXT_PUBLIC_SUPABASE_URL=
