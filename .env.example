# Google Cloud Translation
GOOGLE_CLOUD_TRANSLATION_API_KEY=

# Yandex Maps
YANDEX_MAPS_API_KEY=

# Expo Push
EXPO_ACCESS_TOKEN=

# Delivery Zone (fill in when client confirms location)
DELIVERY_ZONE_CENTER_LAT=41.2995
DELIVERY_ZONE_CENTER_LNG=69.2401
